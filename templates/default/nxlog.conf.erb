<% if node['platform'] == 'windows' %>
define ROOT <%= @root_dir %>

ModuleDir %ROOT%/modules
CacheDir  %ROOT%/data
Pidfile   %ROOT%/data/nxlog.pid
SpoolDir  %ROOT%/data

<% # this seems wrong, but it's what works -%>
Include   %ROOT%/conf/nxlog.conf.d/\\*.conf
<% else %>
User      <%= @user %>
Group     <%= @group %>

Include   <%= @conf_dir %>/nxlog.conf.d/*.conf
<% end %>

LogLevel  <%= @log_level %>
LogFile   <%= @log_file %>

<Extension syslog_module>
  Module xm_syslog
</Extension>

<Extension _json>
    Module xm_json
</Extension>

# defines a null output to work around issue with commas in default output
# list
<Output null_output>
  Module om_null
</Output>
